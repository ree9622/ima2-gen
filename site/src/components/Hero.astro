---
import CodeCopy from './CodeCopy.astro';
import Screenshot from './Screenshot.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const crossLangUrl =
  lang === 'en'
    ? 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ko.md'
    : 'https://lidge-jun.github.io/ima2-gen/?lang=en';
---

<section class="hero" id="top">
  <div class="frame hero-grid">
    <div class="hero-text reveal">
      <div class="eyebrow">{t(lang, 'hero.eyebrow')}</div>
      <h1 class="h-display" id="hero-h1" aria-describedby="hero-sub">
        <span class="h-line">{t(lang, 'hero.h1.line1')}</span><br /><span class="h-line">{t(lang, 'hero.h1.line2')}</span><br /><span class="h-line em">{t(lang, 'hero.h1.em')}</span>
      </h1>
      <p class="sub" id="hero-sub">{t(lang, 'hero.sub')}</p>
      <CodeCopy command={t(lang, 'hero.cta.cmd')} />
      <details class="oneclick-details">
        <summary class="oneclick-summary">
          {lang === 'ko' ? '원클릭 설치 (npm 필요 없음)' : 'One-Click Install (no npm required)'}
          <span class="oneclick-chevron" aria-hidden="true"></span>
        </summary>
        <div class="oneclick-body">
          <p class="oneclick-desc">
            {lang === 'ko'
              ? 'Node.js가 없어도 됩니다. 환경을 감지하고, 필요하면 Node LTS를 설치한 뒤 ima2-gen을 설치합니다.'
              : "Don't have Node.js? The script detects your environment, installs Node LTS if needed, then installs ima2-gen."}
          </p>
          <div class="oneclick-cmd">
            <span class="oneclick-os">macOS</span>
            <code>curl -fsSL https://lidge-jun.github.io/ima2-gen/install-mac.sh | bash</code>
          </div>
          <div class="oneclick-cmd">
            <span class="oneclick-os">Windows</span>
            <code>irm https://lidge-jun.github.io/ima2-gen/install-windows.ps1 | iex</code>
          </div>
          <div class="oneclick-cmd">
            <span class="oneclick-os">Linux / WSL</span>
            <code>curl -fsSL https://lidge-jun.github.io/ima2-gen/install-linux.sh | bash</code>
          </div>
        </div>
      </details>
      <a class="ko-link" href={crossLangUrl} target={lang === 'en' ? '_blank' : undefined} rel={lang === 'en' ? 'noopener' : undefined}>
        {t(lang, 'hero.cross.lang')}
      </a>
    </div>
    <div class="hero-shot reveal">
      <Screenshot
        src="screenshots/classic-generate-light.png"
        alt={t(lang, 'hero.shot.alt')}
        eager
      />
    </div>
  </div>
</section>

<style>
  .hero {
    padding: 128px 0 112px;
    border-bottom: 1px solid var(--line);
    position: relative;
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 56px;
    align-items: center;
  }
  .hero-text h1 {
    /* Cap at 60px so the longest Korean line ("마음에 든 한 장,") fits without internal wrap. */
    font-size: clamp(40px, 4.6vw, 60px);
    margin-bottom: 32px;
    letter-spacing: -0.04em;
  }
  /* Each <br>-separated unit stays on its own line — no mid-line wrap at any viewport. */
  .hero-text h1 .h-line {
    display: inline-block;
    white-space: nowrap;
  }
  @media (max-width: 480px) {
    /* Allow wrap on very narrow screens to prevent overflow. */
    .hero-text h1 .h-line { white-space: normal; }
  }
  .hero-text .sub {
    font-size: 20px;
    color: var(--text-dim);
    max-width: 540px;
    margin-bottom: 36px;
    line-height: 1.6;
  }
  .hero-shot {
    position: relative;
  }
  .hero-shot::before {
    content: '';
    position: absolute;
    inset: -16px -24px;
    background: radial-gradient(ellipse at center, rgba(201, 111, 59, 0.10), transparent 70%);
    pointer-events: none;
    z-index: 0;
    border-radius: 24px;
  }
  .hero-shot :global(.screenshot) {
    position: relative;
    z-index: 1;
    box-shadow: 0 24px 60px -28px rgba(0, 0, 0, 0.6);
  }
  .ko-link {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    border-bottom: 1px solid var(--line);
    padding-bottom: 4px;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .ko-link:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .oneclick-details {
    margin-top: 12px;
    margin-bottom: 12px;
  }
  .oneclick-summary {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--text-dim);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 0;
    border-bottom: 1px solid var(--line);
    transition: color 160ms ease, border-color 160ms ease;
    list-style: none;
  }
  .oneclick-summary::-webkit-details-marker { display: none; }
  .oneclick-summary::marker { content: ''; }
  .oneclick-summary:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .oneclick-chevron {
    display: inline-block;
    width: 0;
    height: 0;
    border-left: 4px solid transparent;
    border-right: 4px solid transparent;
    border-top: 5px solid currentColor;
    transition: transform 200ms ease;
  }
  .oneclick-details[open] .oneclick-chevron {
    transform: rotate(180deg);
  }
  .oneclick-body {
    margin-top: 12px;
    padding: 14px 16px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid var(--line);
    border-radius: 6px;
    max-width: 540px;
  }
  .oneclick-desc {
    font-size: 13px;
    color: var(--text-dim);
    margin: 0 0 12px;
    line-height: 1.5;
  }
  .oneclick-cmd {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 6px;
  }
  .oneclick-cmd:last-child { margin-bottom: 0; }
  .oneclick-os {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--accent);
    min-width: 72px;
    flex-shrink: 0;
  }
  .oneclick-cmd code {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    background: rgba(255, 255, 255, 0.04);
    padding: 5px 10px;
    border-radius: 4px;
    border: 1px solid var(--line);
    overflow-x: auto;
    white-space: nowrap;
    flex: 1;
  }

  @media (max-width: 768px) {
    .hero { padding: 80px 0 72px; }
    .hero-grid { grid-template-columns: 1fr; gap: 36px; }
    .hero-text .sub { font-size: 18px; }
    .hero-shot::before { inset: -8px -12px; }
    .oneclick-cmd { flex-direction: column; align-items: flex-start; gap: 4px; }
    .oneclick-os { min-width: auto; }
  }
</style>
