---
import CodeCopy from './CodeCopy.astro';
import { t, type Lang } from '../i18n/strings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
const repoUrl = 'https://github.com/lidge-jun/ima2-gen';
const npmUrl = 'https://www.npmjs.com/package/ima2-gen';
const koReadme = 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ko.md';
const jaReadme = 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.ja.md';
const zhReadme = 'https://github.com/lidge-jun/ima2-gen/blob/main/docs/README.zh-CN.md';
---

<section class="std install-section" id="install">
  <div class="frame">
    <div class="section-tag reveal">{t(lang, 'install.tag')}</div>
    <h2 class="h-section section-h reveal">
      {t(lang, 'install.h.before')}<span class="em">{t(lang, 'install.h.em')}</span>
    </h2>
    <p class="section-lede reveal">{t(lang, 'install.lede')}</p>
    <div class="install-grid">
      <div class="install-codes reveal">
        <CodeCopy command="npm install -g ima2-gen" />
        <CodeCopy command="ima2 setup" />
        <CodeCopy command="ima2 serve" />
      </div>
      <div class="install-meta reveal">
        <div class="oneclick">
          <p class="oneclick-title">{lang === 'ko' ? '원클릭 설치 (npm 필요 없음)' : 'One-Click Install (no npm required)'}</p>
          <div class="oneclick-cmds">
            <div class="oneclick-row">
              <span class="oneclick-os">macOS</span>
              <code>curl -fsSL https://lidge-jun.github.io/ima2-gen/install-mac.sh | bash</code>
            </div>
            <div class="oneclick-row">
              <span class="oneclick-os">Windows</span>
              <code>irm https://lidge-jun.github.io/ima2-gen/install-windows.ps1 | iex</code>
            </div>
            <div class="oneclick-row">
              <span class="oneclick-os">Linux / WSL</span>
              <code>curl -fsSL https://lidge-jun.github.io/ima2-gen/install-linux.sh | bash</code>
            </div>
          </div>
        </div>
        <div class="badges">
          <span class="badge npm">{t(lang, 'install.badge.npm')}</span>
          <span class="badge">{t(lang, 'install.badge.node')}</span>
          <span class="badge">{t(lang, 'install.badge.mit')}</span>
        </div>
        <ul class="links" aria-label={t(lang, 'install.links.aria')}>
          <li>
            <a href={repoUrl} target="_blank" rel="noopener">
              <span>{t(lang, 'install.link.repo')}</span><span class="arrow">↗</span>
            </a>
          </li>
          <li>
            <a href={npmUrl} target="_blank" rel="noopener">
              <span>{t(lang, 'install.link.npm')}</span><span class="arrow">↗</span>
            </a>
          </li>
          <li>
            <a href={koReadme} target="_blank" rel="noopener">
              <span>{t(lang, 'install.link.ko')}</span><span class="arrow">↗</span>
            </a>
          </li>
          <li>
            <a href={jaReadme} target="_blank" rel="noopener">
              <span>{t(lang, 'install.link.ja')}</span><span class="arrow">↗</span>
            </a>
          </li>
          <li>
            <a href={zhReadme} target="_blank" rel="noopener">
              <span>{t(lang, 'install.link.zh')}</span><span class="arrow">↗</span>
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>
</section>

<style>
  .install-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 56px;
  }
  .install-codes {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .install-meta {
    display: flex;
    flex-direction: column;
    gap: 18px;
    padding-top: 4px;
  }
  .badges {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  .badge {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 5px 11px;
    border: 1px solid var(--line);
    border-radius: 3px;
    color: var(--text-dim);
  }
  .badge.npm {
    color: var(--accent);
    border-color: var(--accent);
  }
  .links {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: 0;
    margin: 0;
  }
  .links li { display: block; }
  .links a {
    font-family: var(--font-display);
    font-size: 14px;
    color: var(--text);
    border-bottom: 1px solid var(--line);
    padding: 10px 0;
    display: flex;
    justify-content: space-between;
    transition: color 160ms ease, border-color 160ms ease;
  }
  .links a:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
  .links a .arrow { color: var(--accent); }

  .oneclick {
    margin-bottom: 18px;
  }
  .oneclick-title {
    font-family: var(--font-display);
    font-size: 13px;
    font-weight: 600;
    color: var(--text);
    margin: 0 0 10px;
    letter-spacing: 0.02em;
  }
  .oneclick-cmds {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .oneclick-row {
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .oneclick-os {
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 600;
    color: var(--accent);
    min-width: 72px;
    flex-shrink: 0;
  }
  .oneclick-row code {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text-dim);
    background: var(--surface-raised, rgba(255,255,255,0.04));
    padding: 5px 10px;
    border-radius: 4px;
    border: 1px solid var(--line);
    overflow-x: auto;
    white-space: nowrap;
    flex: 1;
  }

  @media (max-width: 768px) {
    .install-grid { grid-template-columns: 1fr; gap: 32px; }
    .oneclick-row { flex-direction: column; align-items: flex-start; gap: 4px; }
    .oneclick-os { min-width: auto; }
  }
</style>
